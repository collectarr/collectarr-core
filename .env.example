COMPOSE_PROJECT_NAME=collectarr

# Optional image overrides for corporate registries or GHCR mirrors.
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
MEILI_IMAGE=getmeili/meilisearch:v1.13
MINIO_IMAGE=minio/minio:RELEASE.2025-04-22T22-12-26Z
API_PYTHON_BASE_IMAGE=python:3.14-slim
SYNC_PYTHON_BASE_IMAGE=python:3.12-slim

APP_NAME=Collectarr
ENVIRONMENT=development
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]
BOOTSTRAP_ADMIN_EMAILS=[]

DATABASE_URL=postgresql+asyncpg://collectarr:collectarr@postgres:5432/collectarr
REDIS_URL=redis://redis:6379/0

MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=collectarr-dev-key

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=collectarr-images
S3_PUBLIC_URL=http://localhost:9000/collectarr-images
S3_MANAGE_PUBLIC_READ_POLICY=true
MIRROR_PROVIDER_IMAGES=false
IMAGE_DOWNLOAD_TIMEOUT_SECONDS=20
MAX_IMAGE_BYTES=10485760
PROVIDER_IMAGE_MAX_LONG_EDGE=1280
PROVIDER_IMAGE_QUALITY=82
WORKER_INDEX_INTERVAL_SECONDS=900

COMICVINE_API_KEY=
COMICVINE_BASE_URL=https://comicvine.gamespot.com/api
COMICVINE_TIMEOUT_SECONDS=20

GCD_BASE_URL=https://www.comics.org/api
GCD_TIMEOUT_SECONDS=20
GCD_SEARCH_LIMIT=20

SYNC_DATABASE_PATH=/data/collectarr-sync.db
SYNC_API_KEY=collectarr-sync-dev-key
SYNC_CHANGE_RETENTION_DAYS=90
