COMPOSE_PROJECT_NAME=collectarr

# Release images
COLLECTARR_CORE_IMAGE=ghcr.io/collectarr/collectarr-core:latest
COLLECTARR_SYNC_IMAGE=ghcr.io/collectarr/collectarr-sync:latest
APP_WEB_IMAGE=nginx:1.28-alpine

# unRAID host paths
APP_WEB_ROOT=/mnt/user/appdata/collectarr/web
POSTGRES_DATA_DIR=/mnt/user/appdata/collectarr/postgres
MEILI_DATA_DIR=/mnt/user/appdata/collectarr/meili
MINIO_DATA_DIR=/mnt/user/appdata/collectarr/minio
SYNC_DATA_DIR=/mnt/user/appdata/collectarr/sync

# Published ports
APP_WEB_PORT=8080
CORE_API_PORT=8010
SYNC_API_PORT=8020
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Core runtime
APP_NAME=Collectarr
ENVIRONMENT=production
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=["http://192.168.1.10:8080"]
BOOTSTRAP_ADMIN_EMAILS=["you@example.com"]

POSTGRES_DB=collectarr
POSTGRES_USER=collectarr
POSTGRES_PASSWORD=replace-with-a-db-password
DATABASE_URL=postgresql+asyncpg://collectarr:replace-with-a-db-password@postgres:5432/collectarr

REDIS_URL=redis://redis:6379/0
REDIS_TIMEOUT_SECONDS=0.5

MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=replace-with-a-meili-master-key

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=collectarr-minio
S3_SECRET_ACCESS_KEY=replace-with-a-minio-password
S3_BUCKET=collectarr-images
S3_PUBLIC_URL=http://192.168.1.10:9000/collectarr-images
S3_MANAGE_PUBLIC_READ_POLICY=true

MIRROR_PROVIDER_IMAGES=false
MIRROR_PROVIDER_IMAGES_ALLOW_RESTRICTED=false
IMAGE_DOWNLOAD_TIMEOUT_SECONDS=20
MAX_IMAGE_BYTES=10485760
PROVIDER_IMAGE_MAX_LONG_EDGE=1280
PROVIDER_IMAGE_QUALITY=82
IMAGE_CACHE_MAX_BYTES=100000000000
IMAGE_CACHE_EVICT_TARGET_BYTES=85000000000
IMAGE_CACHE_CLEANUP_BATCH_SIZE=250

WORKER_INDEX_INTERVAL_SECONDS=900
WORKER_PROVIDER_INGEST_INTERVAL_SECONDS=30
WORKER_PROVIDER_INGEST_BATCH_SIZE=5
WORKER_PROVIDER_INGEST_STALE_AFTER_SECONDS=1800

PROVIDER_SEARCH_RATE_LIMIT_REQUESTS=30
PROVIDER_SEARCH_RATE_LIMIT_WINDOW_SECONDS=60
PROVIDER_SEARCH_CACHE_TTL_SECONDS=21600
PROVIDER_SEARCH_CACHE_MAX_ENTRIES=2048
PROVIDER_SEARCH_RETRY_ATTEMPTS=1
PROVIDER_SEARCH_BACKOFF_SECONDS=300
PROVIDER_SEARCH_COMICVINE_FALLBACK_ENABLED=true

COMICVINE_API_KEY=
COMICVINE_BASE_URL=https://comicvine.gamespot.com/api
COMICVINE_TIMEOUT_SECONDS=20

GCD_BASE_URL=https://www.comics.org/api
GCD_TIMEOUT_SECONDS=20
GCD_SEARCH_LIMIT=20

TMDB_API_READ_ACCESS_TOKEN=
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
TMDB_TIMEOUT_SECONDS=20
TMDB_SEARCH_LIMIT=20
TMDB_LANGUAGE=en-US

# Sync runtime
SYNC_DATABASE_PATH=/data/collectarr-sync.db
SYNC_API_KEY=replace-with-a-unique-sync-key
SYNC_CHANGE_RETENTION_DAYS=90